# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/clothy"

# ─── Telegram ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_ID=""
# Secret token Telegram includes in webhook requests so we can verify they're genuine (generate: openssl rand -hex 32)
TELEGRAM_WEBHOOK_SECRET=""

# ─── JWT (generate: openssl rand -base64 32) ─────────────
JWT_SECRET=""

# ─── Storage (VPS / S3-compatible) ───────────────────────
# Leave S3_BUCKET empty to use local filesystem (dev only)
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_CDN_URL=""

# ─── Image domain (your VPS hostname for next/image) ─────
VPS_HOSTNAME=""
